# Copy to .env and fill in. .env is gitignored and injected into the container at
# runtime via docker-compose env_file (never baked into the image).

# --- GitHub Copilot MCP (mcp.json "github" server) ---
# Resolved into the Authorization: Bearer header for https://api.githubcopilot.com/mcp/.
# Without this the header is "Bearer " and GitHub returns 403 forbidden.
# Note: the name is lower-case and must match the ${input:github_mcp_pat} id in mcp.json.
github_mcp_pat=

# --- Yandex 360 MCP (mcp.json "y360" server, run via `uvx y360-mcp`) ---
# Required for y360-mcp to authenticate against Yandex 360 (stdio mode).
YANDEX_OAUTH_TOKEN=
YANDEX_ORG_ID=

# --- App ---
# BOT_TOKEN=
# Optional: override where mcp.json is read from (defaults to <cwd>/mcp.json).
# MCP_CONFIG_PATH=
