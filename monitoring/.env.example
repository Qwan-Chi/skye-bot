# Grafana Cloud: Connections → Hosted Logs and Hosted Prometheus.
GRAFANA_LOKI_URL=https://logs-prod-<region>.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=<instance-id>
GRAFANA_LOKI_TOKEN=<access-policy-token>
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-<region>.grafana.net/api/prom/push
GRAFANA_PROMETHEUS_USER=<instance-id>
GRAFANA_PROMETHEUS_TOKEN=<access-policy-token>

# Uptime Kuma listens only on localhost; access it with an SSH tunnel.
UPTIME_KUMA_PORT=3002
